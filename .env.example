# ─── Pharmacy RAG System — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# Pinecone vector database (required for full RAG pipeline)
# Sign up free at https://www.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1

# HuggingFace (optional — needed only to download gated models)
# Obtain at https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=your_huggingface_token_here

# OpenAI (optional — alternative generation backend)
OPENAI_API_KEY=your_openai_api_key_here_optional

# ngrok (required only when running Streamlit inside Google Colab)
# Obtain at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTH_TOKEN=your_ngrok_token_here
